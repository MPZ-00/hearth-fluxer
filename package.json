{
    "name": "hearth",
    "version": "0.2.1",
    "description": "Selective presence Discord bot: appear online only to your support circle",
    "main": "dist/index.js",
    "type": "commonjs",
    "scripts": {
        "dev": "tsx watch src/index.ts --log-level debug",
        "build": "tsc && cp -r src/db/migrations dist/db/",
        "start": "node dist/index.js",
        "deploy": "tsx scripts/deploy-commands.ts",
        "deploy:dev": "tsx scripts/deploy-dev-commands.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
        "prepare": "husky",
        "setup:official": "tsx scripts/setup-server.ts official",
        "setup:dev": "tsx scripts/setup-server.ts dev"
    },
    "keywords": [
        "discord",
        "bot",
        "presence",
        "privacy"
    ],
    "author": "MPZ-00",
    "license": "MIT",
    "engines": {
        "node": ">=22.12.0"
    },
    "lint-staged": {
        "*.{ts,js,json}": "prettier --write"
    },
    "dependencies": {
        "better-sqlite3": "^12.10.0",
        "discord.js": "^14.26.4",
        "drizzle-orm": "^0.45.2"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.9.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.5",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "prettier": "^3.5.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}
