FLUXER_TOKEN=
CLIENT_ID=
# Override for self-hosted Fluxer instances
FLUXER_API_BASE_URL=https://api.fluxer.app
HEARTH_GUILD_ID=
# Channel invites are created in (see PORTING.md, no channel-list endpoint wired yet)
HEARTH_INVITE_CHANNEL_ID=
DB_PATH=./data/hearth.db

# Optional: invite link for the official/support server, shown in /help
SUPPORT_SERVER_URL=

# Optional: channel ID for admin alerts (failed kicks, etc.)
ADMIN_CHANNEL_ID=

# Optional: guild to scan for observer role (defaults to HEARTH_GUILD_ID)
OBSERVER_GUILD_ID=
# Role name whose members get verbose presence logging in dev mode
OBSERVER_ROLE=tester
